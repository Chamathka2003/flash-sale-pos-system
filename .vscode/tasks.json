{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend: Run Django Server",
      "type": "shell",
      "command": "python",
      "args": [
        "manage.py",
        "runserver"
      ],
      "cwd": "${workspaceFolder}/backend",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Starting development server",
          "endsPattern": "^Quit the server"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Frontend: Run React Dev Server",
      "type": "shell",
      "command": "npm",
      "args": [
        "start"
      ],
      "cwd": "${workspaceFolder}/frontend",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "webpack.*compiled",
          "endsPattern": "npm ERR!"
        }
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "new"
      }
    },
    {
      "label": "Backend: Run Load Test",
      "type": "shell",
      "command": "python",
      "args": [
        "load_test.py"
      ],
      "cwd": "${workspaceFolder}/backend",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: Populate 100k Records",
      "type": "shell",
      "command": "python",
      "args": [
        "populate_data.py"
      ],
      "cwd": "${workspaceFolder}/backend",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Backend: Run Migrations",
      "type": "shell",
      "command": "python",
      "args": [
        "manage.py",
        "migrate"
      ],
      "cwd": "${workspaceFolder}/backend",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      }
    },
    {
      "label": "Backend: Make Migrations",
      "type": "shell",
      "command": "python",
      "args": [
        "manage.py",
        "makemigrations"
      ],
      "cwd": "${workspaceFolder}/backend",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      }
    },
    {
      "label": "Frontend: Install Dependencies",
      "type": "shell",
      "command": "npm",
      "args": [
        "install"
      ],
      "cwd": "${workspaceFolder}/frontend",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      }
    },
    {
      "label": "Backend: Install Dependencies",
      "type": "shell",
      "command": "pip",
      "args": [
        "install",
        "-r",
        "requirements.txt"
      ],
      "cwd": "${workspaceFolder}/backend",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "new"
      }
    },
    {
      "label": "Project: Full Setup",
      "type": "shell",
      "command": "echo",
      "args": [
        "Running full setup..."
      ],
      "dependsOn": [
        "Backend: Install Dependencies",
        "Frontend: Install Dependencies"
      ],
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": []
    }
  ]
}
